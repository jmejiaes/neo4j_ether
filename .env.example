# Copy to .env and fill in. Never commit the real .env.

# Neo4j (local Community via Docker for heavy loads — see docs/adr/0005)
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=change-me

# BigQuery: auth via `gcloud auth application-default login` (no key needed here),
# or set GOOGLE_APPLICATION_CREDENTIALS to a service-account JSON path.
GCP_PROJECT=your-gcp-project-id

# Etherscan (legacy fallback only; primary source is BigQuery — see docs/adr/0001)
API_KEY=your-etherscan-key
